# Kite Connect credentials and user settings
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret
KITE_ACCESS_TOKEN=your_kite_access_token
KITE_USER_ID=your_kite_user_id

# Optional defaults
KITE_DEFAULT_PRODUCT=MIS
KITE_DEFAULT_VARIETY=regular
KITE_ORDER_VALIDITY=DAY

# Stop loss configuration
KITE_STOP_LOSS_MINIMUM_AMOUNT=10.0
KITE_STOP_LOSS_PERCENTAGE=0.10
